{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "sdd-orchestrator": {
      "model": "<your-provider/your-model>",
      "mode": "primary",
      "description": "Agent Teams Orchestrator (single mode) - the only agent; runs each SDD phase as a subtask",
      "prompt": "{file:./AGENTS.md}",
      "permission": {
        "task": {
          "*": "deny",
          "general": "allow"
        }
      },
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "delegate": true,
        "delegation_read": true,
        "delegation_list": true
      }
    }
  }
}
