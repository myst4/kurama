{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "kurama-orchestrator": {
      "model": "<your-provider/your-model>",
      "mode": "primary",
      "description": "Kurama Orchestrator (kurama profile) - coordinates the kurama-suffixed per-phase sub-agents, never does work inline. Switch to it with Tab.",
      "prompt": "{file:./AGENTS.md}",
      "permission": {
        "task": {
          "*": "deny",
          "sdd-*-kurama": "allow"
        }
      },
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "delegate": true,
        "delegation_read": true,
        "delegation_list": true
      }
    },
    "sdd-init-kurama": {
      "model": "<your-provider/your-model>",
      "mode": "subagent",
      "hidden": true,
      "description": "Bootstrap SDD context and project configuration",
      "prompt": "{file:~/.config/opencode/prompts/sdd/sdd-init.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "sdd-explore-kurama": {
      "model": "<your-provider/your-model>",
      "mode": "subagent",
      "hidden": true,
      "description": "Investigate codebase and think through ideas",
      "prompt": "{file:~/.config/opencode/prompts/sdd/sdd-explore.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "sdd-propose-kurama": {
      "model": "<your-provider/your-model>",
      "mode": "subagent",
      "hidden": true,
      "description": "Create change proposals from explorations",
      "prompt": "{file:~/.config/opencode/prompts/sdd/sdd-propose.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "sdd-spec-kurama": {
      "model": "<your-provider/your-model>",
      "mode": "subagent",
      "hidden": true,
      "description": "Write detailed specifications from proposals",
      "prompt": "{file:~/.config/opencode/prompts/sdd/sdd-spec.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "sdd-design-kurama": {
      "model": "<your-provider/your-model>",
      "mode": "subagent",
      "hidden": true,
      "description": "Create technical design from proposals",
      "prompt": "{file:~/.config/opencode/prompts/sdd/sdd-design.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "sdd-tasks-kurama": {
      "model": "<your-provider/your-model>",
      "mode": "subagent",
      "hidden": true,
      "description": "Break down specs and designs into implementation tasks",
      "prompt": "{file:~/.config/opencode/prompts/sdd/sdd-tasks.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "sdd-apply-kurama": {
      "model": "<your-provider/your-model>",
      "mode": "subagent",
      "hidden": true,
      "description": "Implement code changes from task definitions",
      "prompt": "{file:~/.config/opencode/prompts/sdd/sdd-apply.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "sdd-verify-kurama": {
      "model": "<your-provider/your-model>",
      "mode": "subagent",
      "hidden": true,
      "description": "Validate implementation against specs",
      "prompt": "{file:~/.config/opencode/prompts/sdd/sdd-verify.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "sdd-archive-kurama": {
      "model": "<your-provider/your-model>",
      "mode": "subagent",
      "hidden": true,
      "description": "Archive completed change artifacts",
      "prompt": "{file:~/.config/opencode/prompts/sdd/sdd-archive.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    }
  }
}
