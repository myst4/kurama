{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/orchestrator-write-guard.sh"
          }
        ]
      },
      {
        "matcher": "Task|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/archive-gate.sh"
          }
        ]
      }
    ]
  }
}
